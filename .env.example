# Copy to .env (or set these in the systemd unit) and adjust.

# Shared access token required by the browser. If unset, the server generates a
# random one and prints it on startup. ALWAYS set a strong value in production:
# this app exposes a shell.
WEBTERM_TOKEN=change-me-to-a-long-random-string

# Bind address / port for the Node process. Keep it on localhost and put nginx
# (with TLS) in front.
WEBTERM_HOST=127.0.0.1
WEBTERM_PORT=8080

# The command run inside the persistent terminal. Defaults to "$SHELL -l".
# Examples:
#   WEBTERM_CMD=/bin/bash
#   WEBTERM_ARGS=-l
# To drop straight into a TUI app instead of a shell:
#   WEBTERM_CMD=opencode
#   WEBTERM_ARGS=
#WEBTERM_CMD=/bin/bash
#WEBTERM_ARGS=-l

# Working directory and locale for the child process.
#WEBTERM_CWD=/home/youruser
#WEBTERM_LANG=C.UTF-8

# Name of the default persistent session.
#WEBTERM_SESSION=default

# Max number of concurrent sessions a token can spawn (via ?session=<name>).
# Guards against unbounded shell creation. Default 8.
#WEBTERM_MAX_SESSIONS=8

# Scrollback kept by the server-side headless terminal (used for snapshots).
#WEBTERM_SCROLLBACK=2000

# Keepalive interval (ms) for the output stream; keep it below the proxy/nginx
# idle timeout.
#WEBTERM_KEEPALIVE_MS=15000
