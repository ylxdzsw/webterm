# Copy to .env (or set these in the systemd unit) and adjust.

# Shared access token, sent by the browser as `Authorization: Bearer <token>`.
# - If left entirely unset, the server generates a random one-off token and
#   prints it on startup (handy for local use).
# - If set, it must not be empty or a known placeholder, or the server refuses
#   to start. Generate a strong value with:  openssl rand -base64 32
# This app exposes a shell, so always use a strong token in production. All
# slots share this one token.
WEBTERM_TOKEN=

# Bind address / port for the Node process when run WITHOUT socket activation
# (e.g. `npm start` for local use). Under systemd socket activation these are
# ignored: the process listens on the unix socket fd it inherits.
WEBTERM_HOST=127.0.0.1
WEBTERM_PORT=8080

# Every server runs the effective user's passwd login shell with -l. If that
# shell is missing or unusable, startup fails clearly.

# Working directory and locale for the child process.
#WEBTERM_CWD=/home/youruser
#WEBTERM_LANG=C.UTF-8

# Scrollback kept by the server-side headless terminal (used for snapshots).
#WEBTERM_SCROLLBACK=2000

# Keepalive interval (ms) for the output stream; keep it below the proxy/nginx
# idle timeout.
#WEBTERM_KEEPALIVE_MS=15000

# Max queued output bytes per browser stream before that stream is closed.
# Reconnects receive a fresh snapshot, so this bounds memory used by slow tabs.
#WEBTERM_SUBSCRIBER_BUFFER_BYTES=4194304
