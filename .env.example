# Copy to .env (or set these in the systemd unit) and adjust.

# Bind address for the Node process when run WITHOUT socket activation.
# Under systemd socket activation this is ignored: the process listens on
# the unix socket fd it inherits.
WEBTERM_HOST=127.0.0.1

# FOR LOCAL DEVELOPMENT ONLY: Set to a port number to enable insecure TCP mode
# without authentication. DO NOT USE IN PRODUCTION. In production, use systemd
# socket activation and nginx authentication.
#WEBTERM_DEV_PORT=8080

# Every server runs the effective user's passwd login shell with -l. If that
# shell is missing or unusable, startup fails clearly.

# Working directory and locale for the child process.
#WEBTERM_CWD=/home/youruser
#WEBTERM_LANG=C.UTF-8

# Keepalive interval (ms) for the output stream; keep it below the proxy/nginx
# idle timeout.
#WEBTERM_KEEPALIVE_MS=15000

# Max queued output bytes per browser stream before that stream is closed.
# Reconnects receive a fresh snapshot, so this bounds memory used by slow tabs.
#WEBTERM_SUBSCRIBER_BUFFER_BYTES=4194304
